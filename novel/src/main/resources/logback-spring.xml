<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 1. 定义全局变量 -->
    <property name="LOG_PATH" value="./logs"/>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- 2. 控制台输出 Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 3. 文件输出与滚动策略 Appender -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/application.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <!-- 按时间和大小滚动的策略 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 归档日志命名格式，%d表示日期，%i表示序号 -->
            <fileNamePattern>${LOG_PATH}/application.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize> <!-- 单个文件最大100MB -->
            <maxHistory>30</maxHistory>     <!-- 保留最近30天的日志 -->
            <totalSizeCap>10GB</totalSizeCap> <!-- 所有日志总大小上限 -->
        </rollingPolicy>
    </appender>

    <!-- 4. 错误日志单独输出 (结合过滤器) -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/error.log</file>
        <!-- 阈值过滤器：只允许 ERROR 及以上级别的日志通过 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- 5. 异步写文件 -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <neverBlock>false</neverBlock>
        <appender-ref ref="FILE"/>
    </appender>
    <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <appender-ref ref="ERROR_FILE"/>
    </appender>

    <!-- 6. 特定包的日志级别控制 -->
    <logger name="com.wuming.novel.mapper" level="INFO"/>      <!-- SQL 摘要由 SqlSummaryInterceptor 输出，避免打印大字段参数 -->
    <logger name="org.springframework.ai" level="DEBUG"/>       <!-- LLM 调用链路 -->
    <logger name="com.baomidou.mybatisplus" level="WARN"/>      <!-- 压制 MyBatis 内部噪音 -->
    <logger name="com.wuming.novel" level="DEBUG"/>

    <!-- 7. 全局根配置 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="ASYNC_FILE"/>
        <appender-ref ref="ASYNC_ERROR"/>
    </root>
</configuration>
