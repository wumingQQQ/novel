# 外部 MySQL
MYSQL_HOST=mysql.example.com
MYSQL_PORT=3306
MYSQL_DATABASE=novel_dev
MYSQL_USERNAME=novel
MYSQL_PASSWORD=replace-with-mysql-password

# 外部 Redis Stack
REDIS_HOST=redis.example.com
REDIS_PORT=6379
REDIS_PWD=

# 认证与公网入口
JWT_SECRET=replace-with-at-least-32-byte-random-secret
JWT_ISSUER=https://chat.example.com
HTTP_PORT=80

# LLM
DS_API_KEY=replace-with-deepseek-api-key
DS_BASE_URL=https://api.deepseek.com
DS_MODEL=deepseek-v4-flash
NOVEL_LLM_MAX_CONCURRENCY=20

# Embedding 与 Reranker
EMBEDDING_API_KEY=replace-with-siliconflow-api-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_BASE_URL=https://api.siliconflow.cn
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 可选邮件通知
USER_MAIL_ENABLED=false
RESEND_API_KEY=
RESEND_MAIL_FROM=
