# 内置 MySQL（默认值可覆盖）
MYSQL_DATABASE=novel

# 必填机密
JWT_SECRET=
DS_API_KEY=
EMBEDDING_API_KEY=

# 可选覆盖项
JWT_ISSUER=https://chat.example.com
HTTP_PORT=80
DS_BASE_URL=https://api.deepseek.com
DS_MODEL=deepseek-v4-flash
NOVEL_LLM_MAX_CONCURRENCY=20

EMBEDDING_BASE_URL=https://api.siliconflow.cn
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_BASE_URL=https://api.siliconflow.cn
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 文件存储：默认 local。仅在设为 cos 时填写以下配置。
NOVEL_STORAGE_TYPE=local
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=
TENCENT_COS_BUCKET_NAME=
TENCENT_COS_KEY_PREFIX=novels
TENCENT_COS_CONNECTION_TIMEOUT_MS=120000
TENCENT_COS_SOCKET_TIMEOUT_MS=120000

# 可选邮件通知
USER_MAIL_ENABLED=false
RESEND_API_KEY=
RESEND_MAIL_FROM=
